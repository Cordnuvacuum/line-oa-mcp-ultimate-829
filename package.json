{
  "name": "line-oa-mcp-ultimate",
  "version": "1.1.0",
  "description": "Operate one or many LINE Official Accounts from any AI agent through natural language. Send broadcasts, design Flex messages, build rich menus, manage audiences, run coupon campaigns, pull insights, and switch between multiple OAs (agency-ready) — all without writing code. Works with Claude Cowork, Claude Code, Cursor, Codex, ChatGPT desktop, OpenClaw, Hermes, and any MCP-compatible host.",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "line",
    "line-oa",
    "line-official-account",
    "line-bot",
    "messaging-api",
    "claude",
    "claude-cowork",
    "cursor",
    "ai-agent",
    "chatbot",
    "thai",
    "marketing-automation"
  ],
  "homepage": "https://github.com/wasintoh/line-oa-mcp-ultimate#readme",
  "bugs": {
    "url": "https://github.com/wasintoh/line-oa-mcp-ultimate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wasintoh/line-oa-mcp-ultimate.git"
  },
  "license": "MIT",
  "author": {
    "name": "Dr. Wasin Treesinthuros (พี่โต)",
    "email": "wasin.toh@gmail.com",
    "url": "https://github.com/wasintoh"
  },
  "contributors": [
    "Innovation Vantage",
    "ForgeAI — AI Transformation Studio"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "line-oa-mcp-ultimate": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "config.example.json"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.5.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
