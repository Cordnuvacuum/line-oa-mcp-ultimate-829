# LINE MCP Server — Environment Variables

# REQUIRED for single-OA mode:
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# OPTIONAL — used for webhook signature validation (line_test_webhook)
LINE_CHANNEL_SECRET=your_channel_secret_here

# OPTIONAL — path to multi-OA config file (default: ~/.line-mcp/config.json)
# LINE_MCP_CONFIG=/path/to/config.json

# OPTIONAL — override the default OA when multi-OA config is used
# LINE_MCP_DEFAULT_OA=main

# OPTIONAL — transport selection. 'stdio' (default) or 'http'.
# Use 'http' to expose a Streamable HTTP endpoint for Claude Cowork's
# "Add custom connector" UI (which accepts only remote URLs).
# MCP_TRANSPORT=http
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=3000
# MCP_HTTP_PATH=/mcp
